DISCORD_TOKEN=your_discord_bot_token
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY_2=your_secondary_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
LOG_LEVEL=INFO

# Confirmation log backend: excel | google_sheets
CONFIRM_LOG_BACKEND=excel

# Excel backend
CONFIRM_EXCEL_PATH=data/confirmed_bets.xlsx

# Google Sheets backend
CONFIRM_GOOGLE_SHEET_ID=
CONFIRM_GOOGLE_CREDENTIALS_JSON=
CONFIRM_GOOGLE_WORKSHEET=confirmed_bets
USD_TO_CAD_RATE=1.36

# Phase 2 odds automation
ODDS_ENABLED=true
ODDS_RAW_WORKSHEET=odds_raw
ODDS_CLEAN_WORKSHEET=odds_clean
ODDS_RANKED_WORKSHEET=odds_ranked
